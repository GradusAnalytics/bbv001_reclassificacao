{
    "containerDefinitions": [
        {
            "name": "container",
            "image": "381491825479.dkr.ecr.us-east-1.amazonaws.com/bbv001_reclassificacao_ecs:prd",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "container-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PPR_API_BASE_URL",
                    "value": "https://ppr.gradusanalytics.com.br"
                },
                {
                    "name": "PPR_API_TOKEN",
                    "value": "65336ea7-7507-46d0-942e-36f7849b336c"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-create-group": "true",
                    "awslogs-group": "/ecs/prd/bbv001_reclassificacao_ecs",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            }
        }
    ],
    "family": "prd-bbv001_reclassificacao_ecs",
    "executionRoleArn": "arn:aws:iam::381491825479:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "2048",
    "memory": "8192",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}
